// prisma/schema.prisma — FULL MERGED SCHEMA with Health Module

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("User")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts          Contact[]
  tasks             Task[]
  emails            Email[]
  vaultEntries      VaultEntry[]
  educationRecords  EducationRecord[]
  personalDocuments PersonalDocument[]
  documentVault     DocumentVault[]
  settings          UserSettings?
  sessions          UserSession[]
  healthProfiles    HealthProfile[]      // ← NEW
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    String   @default("unknown device")
  browser   String   @default("unknown browser")
  os        String   @default("unknown OS")
  ipAddress String   @default("unknown IP")
  location  String   @default("Location Unknown")
  createdAt DateTime @default(now())
  expiresAt DateTime
  UserAgent String   @default("") @db.Text
  lastActive DateTime @default(now())
  revokedAt DateTime?
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([revokedAt, expiresAt])
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Appearance
  theme           String  @default("dark")
  accentColor     String  @default("#c9a96e")
  compactMode     Boolean @default(false)
  defaultLanding  String  @default("contacts")
  defaultView     String  @default("cards")

  // Session
  sessionTimeout  Int     @default(0)

  // Email preferences
  defaultSenderName String @default("")
  defaultFromEmail  String @default("")
  emailSignature    String @default("") @db.Text
  bccSelf           Boolean @default(false)
  quickRecipients   String  @default("[]")

  // Contact preferences
  defaultContactSort       String @default("recent")
  contactSearchFields      String @default("[\"name\",\"phone\",\"email\"]")
  importDuplicateHandling  String @default("skip")

  // ── Health preferences (NEW) ──────────────────────────────────────────
  healthWeightUnit    String  @default("kg")       // kg | lbs
  healthHeightUnit    String  @default("cm")       // cm | ft
  healthTempUnit      String  @default("celsius")  // celsius | fahrenheit
  healthGlucoseUnit   String  @default("mgdl")     // mgdl | mmoll
  healthDefaultPerson String  @default("")         // profileId of default person
  healthShowReminders Boolean @default(true)       // appointment reminders
  healthApptReminderDays Int  @default(1)          // days before appointment to remind

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  tag       String   @default("personal")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  priority  String   @default("med")
  due       String?
  dueTime   String?
  done      Boolean  @default(false)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([done, dueTime])
}

model Email {
  id          String   @id @default(cuid())
  sender      String
  senderEmail String
  subject     String
  body        String
  preview     String?
  tab         String   @default("inbox")
  unread      Boolean  @default(true)
  starred     Boolean  @default(false)
  sentAt      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VaultEntry {
  id                 String   @id @default(cuid())
  name               String
  userId_field       String?
  password           String
  registrationNumber String?
  link               String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EducationRecord {
  id           String   @id @default(cuid())
  personName   String
  level        String
  institution  String?
  board        String?
  year         String?
  percentage   String?
  rollNumber   String?
  notes        String?
  fileUrl      String?  @db.Text
  fileName     String?
  fileType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PersonalDocument {
  id           String   @id @default(cuid())
  personName   String
  docType      String
  docNumber    String?
  issuedBy     String?
  issuedDate   String?
  expiryDate   String?
  notes        String?
  fileUrl      String?  @db.Text
  fileName     String?
  fileType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DocumentVault {
  id          String   @id @default(cuid())
  name        String
  tag         String?
  idType      String?
  description String?
  fileUrl     String?  @db.Text
  fileName    String?
  fileType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ══════════════════════════════════════════════════════════════════
// HEALTH MODULE — NEW MODELS
// ══════════════════════════════════════════════════════════════════

// ── Family Member Health Profile ──────────────────────────────────
model HealthProfile {
  id              String   @id @default(cuid())
  personName      String
  relation        String   @default("self")   // self | spouse | child | parent | sibling | other
  dateOfBirth     String?                      // YYYY-MM-DD
  gender          String?                      // male | female | other
  bloodGroup      String?                      // A+ | A- | B+ | B- | AB+ | AB- | O+ | O-
  allergies       String?  @db.Text            // comma-separated or free text
  chronicConditions String? @db.Text
  emergencyContact  String?
  photoUrl        String?  @db.Text            // base64 or URL
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  records         HealthRecord[]
  vitals          VitalRecord[]
  medications     Medication[]
  appointments    HealthAppointment[]

  @@index([userId])
}

// ── Health Records (lab reports, consultations, vaccinations, etc.) ──
model HealthRecord {
  id          String   @id @default(cuid())
  profileId   String
  profile     HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Record metadata
  type        String   // blood_test | urine_test | imaging | vaccination | doctor_visit |
                       // dental | eye_exam | mental_health | surgery | allergy | general
  title       String
  date        String   // YYYY-MM-DD
  doctor      String?
  hospital    String?
  diagnosis   String?  @db.Text
  notes       String?  @db.Text

  // Lab results stored as JSON array: [{name, value, unit, normalMin, normalMax, status}]
  labResults  String?  @db.Text

  // File attachment
  fileUrl     String?  @db.Text
  fileName    String?
  fileType    String?  // image | pdf | doc

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String

  @@index([profileId])
  @@index([userId])
  @@index([date])
  @@index([type])
}

// ── Vital Signs Tracking ────────────────────────────────────────────
model VitalRecord {
  id          String   @id @default(cuid())
  profileId   String
  profile     HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date        String   // YYYY-MM-DD
  time        String?  // HH:MM

  // All vital measurements (null means not recorded)
  systolic    Int?     // BP systolic in mmHg
  diastolic   Int?     // BP diastolic in mmHg
  heartRate   Int?     // bpm
  weight      Float?   // kg (store in kg, display in user's unit)
  height      Float?   // cm
  temperature Float?   // Celsius (store in C, display in user's unit)
  bloodSugar  Float?   // mg/dL fasting (store in mg/dL)
  bloodSugarType String? @default("fasting") // fasting | post_meal | random
  spo2        Int?     // SpO2 percentage
  bmi         Float?   // calculated or entered
  respiratoryRate Int? // breaths per minute

  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String

  @@index([profileId])
  @@index([userId])
  @@index([date])
}

// ── Medications ────────────────────────────────────────────────────
model Medication {
  id           String   @id @default(cuid())
  profileId    String
  profile      HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name         String
  genericName  String?
  dosage       String?       // e.g., "500mg"
  frequency    String?       // e.g., "twice daily"
  route        String?       // oral | injection | topical | inhaled | other
  startDate    String?       // YYYY-MM-DD
  endDate      String?       // null = ongoing
  prescribedBy String?
  specialty    String?       // e.g., "Cardiologist"
  purpose      String?       // why prescribed
  sideEffects  String?       @db.Text
  isActive     Boolean       @default(true)
  notes        String?       @db.Text

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  userId       String

  @@index([profileId])
  @@index([userId])
  @@index([isActive])
}

// ── Doctor Appointments ────────────────────────────────────────────
model HealthAppointment {
  id          String   @id @default(cuid())
  profileId   String
  profile     HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title       String
  doctor      String?
  specialty   String?
  hospital    String?
  date        String   // YYYY-MM-DD
  time        String?  // HH:MM
  status      String   @default("scheduled") // scheduled | completed | cancelled | missed
  reason      String?
  outcome     String?  @db.Text
  followUpDate String?
  notes       String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String

  @@index([profileId])
  @@index([userId])
  @@index([date])
  @@index([status])
}
