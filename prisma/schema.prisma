// prisma/schema.prisma — FULL MERGED SCHEMA
// Replace your existing schema.prisma with this complete version

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("User")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts          Contact[]
  tasks             Task[]
  emails            Email[]
  vaultEntries      VaultEntry[]
  educationRecords  EducationRecord[]
  personalDocuments PersonalDocument[]
  documentVault     DocumentVault[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  tag       String   @default("personal") // personal | family | work | emergency
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  priority  String   @default("med") // high | med | low
  due       String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Email {
  id          String   @id @default(cuid())
  sender      String
  senderEmail String
  subject     String
  body        String
  preview     String?
  tab         String   @default("inbox") // inbox | sent | starred
  unread      Boolean  @default(true)
  starred     Boolean  @default(false)
  sentAt      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Password / Credential Vault ───────────────────────────────────────────────
model VaultEntry {
  id                 String   @id @default(cuid())
  name               String                    // label / owner e.g. "Ranjan", "My Bank"
  userId_field       String?                   // login username or user ID
  password           String                    // stored plain (user controls this)
  registrationNumber String?                   // for educational / govt portals
  link               String?                   // direct URL to the platform
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Education Records ────────────────────────────────────────────────────────
model EducationRecord {
  id           String   @id @default(cuid())
  personName   String                         // "Self", "Ranjan", "Mom" — filter tag
  level        String                         // "10th", "12th", "Graduation", custom
  institution  String?
  board        String?                        // CBSE, CGBSE, VTU, etc.
  year         String?
  percentage   String?
  rollNumber   String?
  notes        String?
  fileUrl      String?  @db.Text             // base64 or URL (image/pdf)
  fileName     String?
  fileType     String?                        // "image" | "pdf"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Personal Identity Documents ──────────────────────────────────────────────
model PersonalDocument {
  id           String   @id @default(cuid())
  personName   String                         // "Self", "Dad", "Ranjan" — filter tag
  docType      String                         // "Aadhaar Card", "PAN Card", "Passport", custom
  docNumber    String?
  issuedBy     String?
  issuedDate   String?
  expiryDate   String?
  notes        String?
  fileUrl      String?  @db.Text             // base64 or URL
  fileName     String?
  fileType     String?                        // "image" | "pdf"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── General Document Vault ───────────────────────────────────────────────────
model DocumentVault {
  id          String   @id @default(cuid())
  name        String                          // document display name
  tag         String?                         // "invoice", "certificate", "photo", custom
  idType      String?                         // "Government", "Personal", "Work", custom
  description String?
  fileUrl     String?  @db.Text             // base64 or URL
  fileName    String?
  fileType    String?                         // "image" | "pdf" | "doc" | other
  fileSize    Int?                            // bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
