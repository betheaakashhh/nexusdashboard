// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
  tasks    Task[]
  emails   Email[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  tag       String   @default("personal") // personal | family | work | emergency
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
}

model Task {
  id        String    @id @default(cuid())
  title     String
  priority  String    @default("med") // high | med | low
  due       String?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Email {
  id          String   @id @default(cuid())
  sender      String
  senderEmail String
  subject     String
  body        String
  preview     String?
  tab         String   @default("inbox") // inbox | sent | starred
  unread      Boolean  @default(true)
  starred     Boolean  @default(false)
  sentAt      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
