// prisma/schema.prisma — FULL MERGED SCHEMA with UserSettings + Task time

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("User")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts          Contact[]
  tasks             Task[]
  emails            Email[]
  vaultEntries      VaultEntry[]
  educationRecords  EducationRecord[]
  personalDocuments PersonalDocument[]
  documentVault     DocumentVault[]
  settings          UserSettings?
  sessions          UserSession[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  device    String  @default("unknown device") // e.g. "Chrome on Windows", "iPhone Safari"
  browser   String  @default("unknown browser") // e.g. "Chrome", "Firefox"
  os        String  @default("unknown OS")      // e.g. "Windows", "iOS"
  ipAddress String  @default("unknown IP") // optional IP address for security monitoring
  location  String  @default("Location Unknown") // optional geolocation based on IP
  createdAt DateTime @default(now())
  expiresAt DateTime
  UserAgent String  @default("") @db.Text // full user agent string for analytics
  lastActive DateTime @default(now())
  revokedAt DateTime?
  updatedAt DateTime @updatedAt



  @@index([userId])
  @@index([revokedAt, expiresAt]) // for efficient session cleanup
  

}
// ── Per-user settings stored in DB (replaces cookie-based settings) ──────────
model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Appearance
  theme           String  @default("dark")       // dark | light | system
  accentColor     String  @default("#c9a96e")
  compactMode     Boolean @default(false)
  defaultLanding  String  @default("contacts")   // contacts | tasks | email | private
  defaultView     String  @default("cards")       // cards | table

  // Session
  sessionTimeout  Int     @default(0)            // 0 | 5 | 15 | 30 | 60

  // Email preferences
  defaultSenderName String @default("")
  defaultFromEmail  String @default("")
  emailSignature    String @default("") @db.Text
  bccSelf           Boolean @default(false)
  quickRecipients   String  @default("[]")       // JSON array stored as string

  // Contact preferences
  defaultContactSort       String @default("recent")  // name | recent | added
  contactSearchFields      String @default("[\"name\",\"phone\",\"email\"]") // JSON array
  importDuplicateHandling  String @default("skip")     // skip | overwrite | merge

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  tag       String   @default("personal") // personal | family | work | emergency
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  priority  String   @default("med") // high | med | low
  due       String?                  // date string YYYY-MM-DD
  dueTime   String?                  // time string HH:MM (24h)
  done      Boolean  @default(false)
  notified  Boolean  @default(false) // whether reminder email was sent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([done, dueTime]) // for cron queries
}

model Email {
  id          String   @id @default(cuid())
  sender      String
  senderEmail String
  subject     String
  body        String
  preview     String?
  tab         String   @default("inbox") // inbox | sent | starred
  unread      Boolean  @default(true)
  starred     Boolean  @default(false)
  sentAt      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Password / Credential Vault ───────────────────────────────────────────────
model VaultEntry {
  id                 String   @id @default(cuid())
  name               String
  userId_field       String?
  password           String
  registrationNumber String?
  link               String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Education Records ────────────────────────────────────────────────────────
model EducationRecord {
  id           String   @id @default(cuid())
  personName   String
  level        String
  institution  String?
  board        String?
  year         String?
  percentage   String?
  rollNumber   String?
  notes        String?
  fileUrl      String?  @db.Text
  fileName     String?
  fileType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Personal Identity Documents ──────────────────────────────────────────────
model PersonalDocument {
  id           String   @id @default(cuid())
  personName   String
  docType      String
  docNumber    String?
  issuedBy     String?
  issuedDate   String?
  expiryDate   String?
  notes        String?
  fileUrl      String?  @db.Text
  fileName     String?
  fileType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── General Document Vault ───────────────────────────────────────────────────
model DocumentVault {
  id          String   @id @default(cuid())
  name        String
  tag         String?
  idType      String?
  description String?
  fileUrl     String?  @db.Text
  fileName    String?
  fileType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
